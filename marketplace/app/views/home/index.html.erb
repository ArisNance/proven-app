              <path d="M158 170l-18 80M194 170l18 80" stroke="#A69A8A" stroke-width="9" stroke-linecap="round"></path>
            </g>

            <g class="pulse">
              <ellipse cx="312" cy="188" rx="62" ry="15" fill="#C1B5A6"></ellipse>
