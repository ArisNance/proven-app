<div class="mt-4 flex flex-wrap gap-2 text-sm text-slate-600">
  <% if controller_name != "sessions" %>
    <%= link_to "Sign in", new_session_path(resource_name), class: "underline hover:text-slate-900" %>
  <% end %>

  <% if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "Create account", new_registration_path(resource_name), class: "underline hover:text-slate-900" %>
  <% end %>

  <% if devise_mapping.recoverable? && controller_name != "passwords" %>
    <%= link_to "Forgot password?", new_password_path(resource_name), class: "underline hover:text-slate-900" %>
  <% end %>
</div>
