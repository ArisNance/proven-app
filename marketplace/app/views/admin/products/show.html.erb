<%= render "shared/breadcrumbs", items: [
  { label: "Admin", path: admin_root_path },
  { label: "Products", path: admin_products_path },
  { label: "Product ##{@product.id}" }
] %>

<%= render "shared/page_header",
  eyebrow: "Admin Products",
  title: @product.name,
  description: "Edit product metadata used in storefront and search.",
  actions: [{ label: "Back to products", path: admin_products_path, style: :secondary }] %>

<section class="grid gap-4 lg:grid-cols-2">
  <article class="surface-panel p-5">
    <h2 class="text-lg font-bold">Edit Product</h2>
    <%= form_with model: @product, url: admin_product_path(@product), method: :patch, class: "mt-3 grid gap-3" do |f| %>
      <div>
        <label class="field-label" for="spree_product_name">Name</label>
        <%= f.text_field :name, class: "input input-bordered mt-1 w-full" %>
      </div>

      <div>
        <label class="field-label" for="spree_product_description">Description</label>
        <%= f.text_area :description, class: "textarea textarea-bordered mt-1 h-32 w-full" %>
      </div>

      <div>
        <label class="field-label" for="spree_product_status">Status</label>
        <%= f.text_field :status, class: "input input-bordered mt-1 w-full" %>
      </div>

      <div>
        <label class="field-label" for="spree_product_price">Price</label>
        <input id="spree_product_price" name="spree_product[price]" value="<%= @product.respond_to?(:price) ? @product.price : "" %>" class="input input-bordered mt-1 w-full">
      </div>

      <div>
        <%= f.submit "Save", class: quick_action_classes(:primary) %>
      </div>
    <% end %>

    <%= button_to "Delete product", admin_product_path(@product), method: :delete, class: "mt-4 inline-flex items-center justify-center rounded-full border border-rose-300 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:bg-rose-50", data: { turbo_confirm: "Delete this product?" } %>
  </article>

  <article class="surface-panel p-5">
    <h2 class="text-lg font-bold">Product Snapshot</h2>
    <ul class="mt-3 space-y-2 text-sm text-slate-700">
      <li>ID: <%= @product.id %></li>
      <li>Slug: <%= @product.slug %></li>
      <li>Status: <span class="<%= status_pill_class(@product.status) %>"><%= @product.status %></span></li>
      <li>Created: <%= l(@product.created_at, format: :short) %></li>
      <li>Updated: <%= l(@product.updated_at, format: :short) %></li>
    </ul>
  </article>
</section>
