<%= render "shared/breadcrumbs", items: [
  { label: "Home", path: root_path },
  { label: "Maker shops", path: makers_shops_path },
  { label: "Create shop" }
] %>

<%= render "shared/page_header",
  eyebrow: "Maker Workspace",
  title: "Create a New Shop",
  description: "Add your public shop identity and submit for admin approval. We also set up billing and payout dependencies.",
  actions: [{ label: "Back to shops", path: makers_shops_path, style: :secondary }] %>

<section class="grid gap-4 xl:grid-cols-[1.1fr_0.9fr]">
  <article class="form-card">
    <%= render "shared/form_error_summary", record: @shop %>

    <%= form_with model: @shop, url: makers_shops_path, class: "grid gap-4", data: { controller: "form-state" } do |f| %>
      <div>
        <label class="field-label" for="shop_name">Shop name <span class="field-meta">Required</span></label>
        <%= f.text_field :name,
          class: "input input-bordered mt-1 w-full",
          required: true,
          aria: { describedby: "shop_name_hint shop_name_error" } %>
        <p class="field-hint" id="shop_name_hint">Use the same name you display on packaging and social accounts.</p>
        <%= inline_field_error(@shop, :name) %>
      </div>

      <div>
        <label class="field-label" for="shop_description">Description <span class="field-meta">Required</span></label>
        <%= f.text_area :description,
          class: "textarea textarea-bordered mt-1 h-28 w-full",
          required: true,
          placeholder: "What do you make, and who is it for?",
          aria: { describedby: "shop_description_hint shop_description_error" } %>
        <p class="field-hint" id="shop_description_hint">Clear descriptions help reviewers approve faster.</p>
        <%= inline_field_error(@shop, :description) %>
      </div>

      <div class="mt-2 flex flex-wrap gap-2">
        <%= f.submit "Submit for approval", class: quick_action_classes(:primary), data: { form_state_target: "submit" } %>
        <%= link_to "Cancel", makers_shops_path, class: quick_action_classes(:secondary) %>
      </div>
    <% end %>
  </article>

  <aside class="space-y-4">
    <section class="surface-panel p-5">
      <h2 class="text-lg font-bold">Submission Checklist</h2>
      <ul class="mt-3 space-y-2 text-sm text-slate-600">
        <li><span class="font-semibold text-rose-700">Incomplete</span> - Maker onboarding completed</li>
        <li><span class="font-semibold text-rose-700">Incomplete</span> - Shop identity and product quality standards defined</li>
        <li><span class="font-semibold text-rose-700">Incomplete</span> - Stripe payout + listing billing prerequisites available</li>
      </ul>
      <p class="mt-2 text-xs text-slate-500">The wizard checklist below marks items as completed/incomplete and lets you jump back to previous steps.</p>
    </section>

    <section class="surface-panel p-5">
      <h2 class="text-lg font-bold">Product Setup</h2>
      <p class="mt-2 text-sm text-slate-600">Use the guided wizard to draft your first listing after creating the shop.</p>
      <section class="mt-3" data-react-component="ProductWizard"></section>
    </section>
  </aside>
</section>
