<%= render "shared/breadcrumbs", items: [
  { label: "Home", path: root_path },
  { label: "Maker shops", path: makers_shops_path },
  { label: @shop.name }
] %>

<% shop_actions = [{ label: "All shops", path: makers_shops_path, style: :secondary }] %>
<% shop_actions << { label: "Upload product", path: new_makers_shop_product_path(@shop), style: :primary } if @shop.approved? %>
<% shop_actions << { label: "New shop", path: new_makers_shop_path, style: :primary } if can_create_shop? %>

<%= render "shared/page_header",
  eyebrow: "Shop Detail",
  title: @shop.name,
  description: @shop.description.presence || "No description provided yet.",
  actions: shop_actions %>

<section class="grid gap-4 lg:grid-cols-3">
  <article class="surface-panel p-5">
    <h2 class="text-lg font-bold">Approval Status</h2>
    <p class="mt-3"><span class="<%= status_pill_class(@shop.state) %>"><%= @shop.state %></span></p>
    <p class="mt-2 text-sm text-slate-600">
      <% if @approval&.reviewed_at.present? %>
        Reviewed <%= time_ago_in_words(@approval.reviewed_at) %> ago.
      <% else %>
        Awaiting reviewer decision.
      <% end %>
    </p>
  </article>

  <article class="surface-panel p-5">
    <h2 class="text-lg font-bold">Billing Status</h2>
    <% if @listing_fee_subscription.present? %>
      <p class="mt-3"><span class="<%= status_pill_class(@listing_fee_subscription.status) %>"><%= @listing_fee_subscription.status %></span></p>
      <p class="mt-2 text-sm text-slate-600">
        Listing fee: <%= number_to_currency(@listing_fee_subscription.unit_amount_cents.to_f / 100) %> each - quantity <%= @listing_fee_subscription.quantity %>
      </p>
    <% elsif @shop.stripe_customer_id.present? %>
      <p class="mt-3"><span class="status-pill bg-sky-50 text-sky-700">Customer created</span></p>
      <p class="mt-2 text-sm text-slate-600">Billing profile exists. Subscription sync will run after listings are detected.</p>
    <% else %>
      <p class="mt-3"><span class="status-pill bg-slate-100 text-slate-700">Pending billing setup</span></p>
      <p class="mt-2 text-sm text-slate-600">Run billing sync after shop approval to prepare listing fees.</p>
    <% end %>

    <div class="mt-4">
      <% if @shop.approved? && @stripe_configured %>
        <%= button_to "Sync billing now", sync_billing_makers_shop_path(@shop), method: :post, class: quick_action_classes(:secondary), form: { data: { turbo: false } } %>
      <% elsif !@shop.approved? %>
        <p class="text-sm text-slate-600">Billing activation unlocks once this shop is approved.</p>
      <% else %>
        <p class="text-sm text-slate-600">Add `STRIPE_SECRET_KEY` in your local env to enable billing sync.</p>
      <% end %>
    </div>
  </article>

  <article class="surface-panel p-5">
    <h2 class="text-lg font-bold">Payout Readiness</h2>
    <% if current_user.maker_profile&.stripe_account_id.present? %>
      <p class="mt-3"><span class="status-pill bg-emerald-50 text-emerald-700">Stripe account connected</span></p>
      <p class="mt-2 text-sm text-slate-600">Payout account ID: <%= current_user.maker_profile.stripe_account_id %></p>
    <% else %>
      <p class="mt-3"><span class="status-pill bg-amber-50 text-amber-800">Action required</span></p>
      <p class="mt-2 text-sm text-slate-600">Connect Stripe Connect onboarding to receive payouts.</p>
    <% end %>

    <div class="mt-4 space-y-2">
      <% if @shop.approved? && @stripe_configured %>
        <% if current_user.maker_profile&.stripe_account_id.blank? %>
          <%= button_to "Connect Stripe payouts", connect_billing_makers_shop_path(@shop), method: :post, class: quick_action_classes(:primary), form: { data: { turbo: false } } %>
        <% end %>
        <p class="text-xs text-slate-500">Uses Stripe test mode when your key starts with `sk_test_`.</p>
      <% elsif !@shop.approved? %>
        <p class="text-sm text-slate-600">This button activates after shop approval.</p>
      <% else %>
        <p class="text-sm text-slate-600">Add `STRIPE_SECRET_KEY` to enable Stripe Connect onboarding.</p>
      <% end %>

      <% if current_user.maker_profile&.stripe_account_id.present? && @stripe_configured %>
        <%= button_to "Resume onboarding", connect_billing_makers_shop_path(@shop), method: :post, class: quick_action_classes(:secondary), form: { data: { turbo: false } } %>
      <% elsif current_user.maker_profile.blank? %>
        <%= link_to "Complete onboarding profile", makers_profile_onboarding_path, class: quick_action_classes(:secondary) %>
      <% end %>
    </div>
  </article>
</section>

<section class="surface-panel mt-4 p-5">
  <h2 class="text-lg font-bold">Public Profile</h2>
  <% if @shop.username.present? %>
    <p class="mt-2 text-sm text-slate-600">Public URL username: <strong><%= @shop.username %></strong></p>
    <div class="mt-3">
      <%= link_to "View public maker profile", makers_public_profile_path(username: @shop.username), class: quick_action_classes(:secondary) %>
    </div>
  <% else %>
    <p class="mt-2 text-sm text-slate-600">Set your public username in maker onboarding to enable your shareable profile URL.</p>
    <div class="mt-3">
      <%= link_to "Complete onboarding profile", makers_profile_onboarding_path, class: quick_action_classes(:secondary) %>
    </div>
  <% end %>
</section>

<section class="surface-panel mt-4 p-5">
  <h2 class="text-lg font-bold">Product Upload</h2>
  <% if @shop.approved? %>
    <p class="mt-2 text-sm text-slate-600">Upload listings for this approved shop. New listings are created as drafts and routed to the admin product approval queue.</p>
    <div class="mt-3 flex flex-wrap gap-2">
      <%= link_to "Upload a product", new_makers_shop_product_path(@shop), class: quick_action_classes(:primary) %>
      <%= link_to "Manage uploaded products", makers_shop_products_path(@shop), class: quick_action_classes(:secondary) %>
    </div>
    <% if @uploaded_products.any? %>
      <div class="mt-4 space-y-2">
        <% @uploaded_products.each do |product| %>
          <article class="rounded-xl border border-[#E8E8E2] p-3">
            <p class="font-semibold text-[#0D0D0D]"><%= product.name %></p>
            <p class="mt-1 text-sm text-[#4A4A42]"><%= number_to_currency(product.price_cents.to_f / 100) %> · <%= product.category %></p>
            <div class="mt-2">
              <%= link_to "View storefront detail", product_path(product.slug.presence || product.id), class: "text-sm font-semibold text-[#0D0D0D] underline decoration-[#CCCCC4] underline-offset-4" %>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  <% else %>
    <p class="mt-2 text-sm text-slate-600">Product uploads become available after this shop is approved.</p>
  <% end %>
</section>
