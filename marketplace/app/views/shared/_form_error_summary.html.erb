<% if record.errors.any? %>
  <section class="form-error-summary" aria-labelledby="error-summary-title" role="alert" aria-live="assertive" tabindex="-1">
    <h2 id="error-summary-title" class="font-semibold text-rose-800">
      <%= pluralize(record.errors.count, "issue") %> needs attention before continuing.
    </h2>
    <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-rose-700">
      <% record.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </section>
<% end %>
