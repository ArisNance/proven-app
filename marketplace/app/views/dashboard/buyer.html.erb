<%= render "shared/breadcrumbs", items: [
  { label: "Home", path: root_path },
  { label: "Buyer Dashboard" }
] %>

<%= render "shared/page_header",
  eyebrow: "Buyer Workspace",
  title: "Your Buyer Dashboard",
  description: "Track purchases, delivery status, and conversations with makers.",
  actions: role_quick_actions %>

<section class="info-grid">
  <article class="metric-tile">
    <p class="metric-label">Past purchases</p>
    <p class="metric-value"><%= @orders_total %></p>
  </article>
  <article class="metric-tile">
    <p class="metric-label">Total spend</p>
    <p class="metric-value"><%= number_to_currency(@orders_total_spend / 100.0) %></p>
  </article>
  <article class="metric-tile">
    <p class="metric-label">Open messages</p>
    <p class="metric-value"><%= @recent_messages.count %></p>
  </article>
  <article class="metric-tile">
    <p class="metric-label">Account role</p>
    <p class="metric-value"><%= role_badge_text %></p>
  </article>
</section>

<section class="mt-4 grid gap-4 xl:grid-cols-[1.2fr_0.8fr]">
  <article class="surface-panel p-5">
    <h2 class="text-xl font-bold">Recent Orders</h2>
    <% if @orders.any? %>
      <div class="data-table-wrap mt-4">
        <table class="data-table">
          <thead>
            <tr>
              <th class="px-3 py-2 text-left">Order</th>
              <th class="px-3 py-2 text-left">Date</th>
              <th class="px-3 py-2 text-left">Status</th>
              <th class="px-3 py-2 text-right">Total</th>
            </tr>
          </thead>
          <tbody>
            <% @orders.each do |order| %>
              <tr>
                <td class="px-3 py-2 font-semibold text-[#0D0D0D]"><%= order.try(:number).presence || "Order ##{order.id}" %></td>
                <td class="px-3 py-2 text-sm text-[#4A4A42]"><%= l(order.created_at.to_date, format: :long) %></td>
                <td class="px-3 py-2 text-sm">
                  <span class="<%= status_pill_class(order.try(:state) || order.try(:payment_state) || "pending") %>"><%= order.try(:state).presence || order.try(:payment_state).presence || "pending" %></span>
                </td>
                <td class="px-3 py-2 text-right text-sm font-semibold text-[#0D0D0D]"><%= number_to_currency(order.try(:total).to_f) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <%= render "shared/empty_state",
        title: "No purchases yet",
        description: "Your completed purchases will appear here once checkout activity starts.",
        action: { label: "Browse products", path: products_path, style: :primary } %>
    <% end %>
  </article>

  <aside class="space-y-4">
    <section class="surface-panel p-5">
      <h2 class="text-lg font-bold">Recent Messages</h2>
      <% if @recent_messages.any? %>
        <ul class="mt-3 space-y-2">
          <% @recent_messages.each do |message| %>
            <li class="rounded-2xl border border-[#E8E8E2] p-3">
              <p class="text-sm text-[#0D0D0D]"><%= truncate(message.body, length: 90) %></p>
              <p class="mt-1 text-xs text-[#8A8A80]"><%= time_ago_in_words(message.created_at) %> ago</p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-2 text-sm text-[#4A4A42]">No buyer messages yet.</p>
      <% end %>
    </section>

    <% if @show_sell_on_proven %>
      <section class="surface-panel border-l-4 border-l-accent p-5">
        <h2 class="text-lg font-bold text-[#0D0D0D]">Ready to sell?</h2>
        <p class="mt-2 text-sm text-[#4A4A42]">Apply to open your maker account and launch a shop on Proven.</p>
        <div class="mt-4">
          <%= link_to "Sell on Proven", makers_onboarding_path, class: quick_action_classes(:primary) %>
        </div>
      </section>
    <% elsif @maker_application.present? %>
      <section class="surface-panel p-5">
        <h2 class="text-lg font-bold text-[#0D0D0D]">Maker Application</h2>
        <p class="mt-2 text-sm text-[#4A4A42]">Status: <span class="<%= status_pill_class(@maker_application.state) %>"><%= @maker_application.state.humanize %></span></p>
        <% if @maker_application.accepted? %>
          <div class="mt-4">
            <%= link_to "Complete maker onboarding", makers_profile_onboarding_path, class: quick_action_classes(:primary) %>
          </div>
        <% else %>
          <div class="mt-4">
            <%= link_to "View application", makers_onboarding_path, class: quick_action_classes(:secondary) %>
          </div>
        <% end %>
      </section>
    <% end %>
  </aside>
</section>

