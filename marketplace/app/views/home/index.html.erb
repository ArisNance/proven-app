<section class="mt-12" data-reveal data-reveal-delay="40">
  <div class="grid gap-8 rounded-[32px] border border-[#E8E8E2] bg-white p-6 shadow-sm md:grid-cols-[1fr_1.1fr] md:items-center md:p-8">
    <div>
      <p class="eyebrow">Meet the Maker</p>
      <h2 class="mt-2 text-3xl font-bold text-[#0D0D0D]">Crafted by real people, not factories.</h2>
      <p class="mt-3 max-w-xl text-base leading-relaxed text-[#4A4A42]">Every featured shop is reviewed and verified by Proven. Discover the story behind the products and support independent makers directly.</p>
    </div>
    <div class="overflow-hidden rounded-3xl border border-[#E8E8E2]">
      <img src="https://storage.googleapis.com/ore-web/Dance%20Happy--sewing%2C%20studio%20shot.JPG" alt="Maker in studio" class="h-[320px] w-full object-cover md:h-[420px]">
    </div>
  </div>
</section>

<section class="mt-10" data-reveal>
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <p class="eyebrow">Featured Makers</p>
      <h2 class="text-3xl font-bold text-[#0D0D0D]">Shops You Can Trust</h2>
    </div>
    <%= link_to "View all products", products_path, class: quick_action_classes(:secondary) %>
  </div>

  <% if @featured_shops.any? %>
    <div class="maker-carousel">
      <% @featured_shops.each_with_index do |shop, index| %>
        <% shop_products = @products_by_shop[shop.id] || [] %>
        <% cover = shop_products.first&.image_url.presence || "https://picsum.photos/seed/shop-#{shop.id}/640/640" %>
        <article class="maker-card" data-reveal data-reveal-delay="<%= [40 + (index * 20), 220].min %>" data-tilt>
          <img src="<%= cover %>" alt="<%= shop.name %>" class="h-44 w-full rounded-2xl object-cover">
          <h3 class="mt-3 text-xl font-bold text-[#0D0D0D]"><%= shop.name %></h3>
          <p class="mt-1 text-sm text-[#4A4A42]">by <%= shop.maker.maker_profile&.display_name || shop.maker.email %></p>
          <p class="mt-1 text-xs text-[#8A8A80]"><%= pluralize(shop_products.count, "product") %> in catalog</p>
        </article>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No makers available yet", description: "Seed or create maker shops to populate the marketplace carousel." %>
  <% end %>
</section>

<section class="mt-10" data-reveal>
  <div class="mb-3 flex items-end justify-between gap-4">
    <div>
      <p class="eyebrow">Shop by Category</p>
      <h2 class="text-3xl font-bold text-[#0D0D0D]">Find Exactly What You Need</h2>
    </div>
  </div>

  <% if @shop_by_category.any? %>
    <div class="shop-by-category-grid">
      <% @shop_by_category.each_with_index do |tile, index| %>
        <%= link_to products_path(category: tile[:name]), class: "category-orb", data: { reveal: true, reveal_delay: [50 + (index * 35), 260].min } do %>
          <div class="category-orb-media">
            <% if tile[:image_url].present? %>
              <img src="<%= tile[:image_url] %>" alt="<%= tile[:name] %>">
            <% else %>
              <div class="grid h-full place-items-center bg-[#F4F4F0] text-xs text-[#8A8A80]">Category</div>
            <% end %>
          </div>
          <p class="text-sm font-semibold text-[#0D0D0D]"><%= tile[:name] %></p>
          <p class="mt-1 text-xs text-[#8A8A80]"><%= pluralize(tile[:count], "item") %></p>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% if @top_search_terms.any? %>
    <div class="mt-8" data-reveal data-reveal-delay="120">
      <p class="text-sm font-semibold uppercase tracking-[0.08em] text-[#8A8A80]">Popular Searches</p>
      <div class="search-chip-cloud">
        <% @top_search_terms.each do |term| %>
          <%= link_to term, products_path(q: term), class: "search-chip" %>
        <% end %>
      </div>
    </div>
  <% end %>
</section>

<section class="mt-10" data-reveal>
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <p class="eyebrow">Gift Guides</p>
      <h2 class="text-3xl font-bold text-[#0D0D0D]">Curated Like Etsy, Verified by Proven</h2>
    </div>
  </div>

  <% if @gift_guides.any? %>
    <div class="story-grid">
      <% @gift_guides.each_with_index do |guide, index| %>
        <%= link_to guide[:path], class: "story-card", data: { reveal: true, reveal_delay: [70 + (index * 40), 220].min } do %>
          <% if guide[:image_url].present? %>
            <img src="<%= guide[:image_url] %>" alt="<%= guide[:title] %>" class="h-48 w-full object-cover">
          <% else %>
            <div class="grid h-48 place-items-center bg-[#F4F4F0] text-sm text-[#8A8A80]">Guide image</div>
          <% end %>
          <div class="p-4">
            <h3 class="text-xl font-bold text-[#0D0D0D]"><%= guide[:title] %></h3>
            <p class="mt-2 text-sm text-[#4A4A42]"><%= guide[:body] %></p>
            <p class="mt-3 text-sm font-semibold text-[#0D0D0D] underline">Explore guide</p>
          </div>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>

<section class="mt-12" data-reveal>
  <div class="mb-4 flex items-end justify-between gap-4">
    <div>
      <p class="eyebrow">Featured Collection</p>
      <h2 class="text-3xl font-bold text-[#0D0D0D]">Curated Marketplace Picks</h2>
    </div>
    <%= link_to "Browse all", products_path, class: quick_action_classes(:secondary) %>
  </div>

  <% if @featured_products.any? %>
    <div class="product-grid">
      <% @featured_products.each_with_index do |product, index| %>
        <div data-reveal data-reveal-delay="<%= [70 + (index * 20), 240].min %>">
          <%= render "shared/product_card", product: product %>
        </div>
      <% end %>
    </div>
  <% else %>
    <%= render "shared/empty_state", title: "No products yet", description: "Add products to the catalog to populate this section." %>
  <% end %>
</section>
