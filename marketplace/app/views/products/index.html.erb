<%= render "shared/breadcrumbs", items: [
  { label: "Home", path: root_path },
  { label: "Shop" }
] %>

<header class="catalog-banner mb-10" data-reveal>
  <div class="relative z-10 grid gap-8 md:grid-cols-[1fr_360px] md:items-center">
    <div>
      <p class="hero-pill"><span class="hero-pill-dot"></span>Marketplace collection</p>
      <h1 class="mt-4 text-5xl font-extrabold leading-tight text-[#0D0D0D] md:text-6xl">Proven Marketplace.</h1>
      <p class="mt-4 max-w-lg text-base text-[#4A4A42]">Explore verified handmade goods by category, variation, and maker. Filters update dynamically from the live catalog.</p>
    </div>
    <div class="hidden md:flex items-center justify-center" data-tilt>
      <img src="https://storage.googleapis.com/ore-web/proven-outline-symbol-logo.png" alt="Proven symbol" class="w-56 rounded-3xl bg-white p-6 shadow-card-float">
    </div>
  </div>
</header>

<%= turbo_frame_tag "products_catalog" do %>
  <section class="listing-shell">
    <aside class="listing-sidebar lg:sticky lg:top-24 lg:max-h-[calc(100vh-7rem)] lg:overflow-y-auto no-scrollbar" data-reveal data-reveal-delay="40">
      <%= form_with url: products_path, method: :get, class: "space-y-6", data: { controller: "catalog-filters", turbo_frame: "products_catalog" } do %>
      <div>
        <div class="mb-2 flex items-center justify-between gap-2">
          <h2 class="font-header text-xl font-bold text-[#0D0D0D]">Filters</h2>
          <span class="tooltip" data-tip="Filters include categories and live product variations from your Spree catalog.">
            <span class="inline-flex h-6 w-6 items-center justify-center rounded-full border border-[#CCCCC4] text-xs text-[#4A4A42]">i</span>
          </span>
        </div>

        <label class="field-label" for="products_search">Search</label>
        <input
          id="products_search"
          name="q"
          value="<%= @query %>"
          type="search"
          placeholder="Search products or makers"
          class="input input-bordered mt-1 w-full rounded-full border-[#CCCCC4] bg-white"
          data-action="input->catalog-filters#queueSubmit"
        >
      </div>

      <div>
        <label class="field-label" for="products_sort">Sort</label>
        <select id="products_sort" name="sort" class="select select-bordered mt-1 w-full rounded-full border-[#CCCCC4] bg-white" data-action="change->catalog-filters#submit">
          <option value="featured" <%= "selected" if @sort == "featured" %>>Featured</option>
          <option value="newest" <%= "selected" if @sort == "newest" %>>Newest</option>
          <option value="price_asc" <%= "selected" if @sort == "price_asc" %>>Price: Low to High</option>
          <option value="price_desc" <%= "selected" if @sort == "price_desc" %>>Price: High to Low</option>
        </select>
      </div>

      <details class="filter-group" open>
        <summary>Categories</summary>
        <div class="mt-3 space-y-2 pb-1">
          <label class="flex cursor-pointer items-center gap-2 rounded-xl px-2 py-2 hover:bg-black/5">
            <input type="radio" name="category" value="" class="radio radio-sm" <%= "checked" if @category.blank? %> data-action="change->catalog-filters#submit">
            <span class="text-sm text-[#4A4A42]">All categories (<%= @products_total %>)</span>
          </label>
          <% @categories.each do |category| %>
            <label class="flex cursor-pointer items-center gap-2 rounded-xl px-2 py-2 hover:bg-black/5">
              <input type="radio" name="category" value="<%= category %>" class="radio radio-sm" <%= "checked" if @category == category %> data-action="change->catalog-filters#submit">
              <span class="text-sm text-[#4A4A42]"><%= category %> (<%= @category_counts[category] %>)</span>
            </label>
          <% end %>
        </div>
      </details>

      <% if @size_group[:values].any? %>
        <details class="filter-group" open>
          <summary>Size</summary>
          <div class="mt-3 space-y-2 pb-1">
            <% @size_group[:values].each do |entry| %>
              <label class="flex cursor-pointer items-center gap-2 rounded-xl px-2 py-1.5 hover:bg-black/5">
                <input
                  type="checkbox"
                  name="size[]"
                  value="<%= entry[:value] %>"
                  class="checkbox checkbox-sm rounded-md"
                  <%= "checked" if @size_filters.include?(entry[:value]) %>
                  data-action="change->catalog-filters#submit"
                >
                <span class="text-sm text-[#4A4A42]"><%= entry[:value] %> (<%= entry[:count] %>)</span>
              </label>
            <% end %>
          </div>
        </details>
      <% end %>

      <details class="filter-group" open>
        <summary>Price Variant</summary>
        <div class="mt-3 space-y-2 pb-1">
          <% @price_groups.each do |group| %>
            <label class="flex cursor-pointer items-center gap-2 rounded-xl px-2 py-1.5 hover:bg-black/5">
              <input
                type="checkbox"
                name="price[]"
                value="<%= group[:key] %>"
                class="checkbox checkbox-sm rounded-md"
                <%= "checked" if @price_filters.include?(group[:key]) %>
                data-action="change->catalog-filters#submit"
              >
              <span class="text-sm text-[#4A4A42]"><%= group[:label] %> (<%= group[:count] %>)</span>
            </label>
          <% end %>
        </div>
      </details>

      <% if @variation_groups.any? %>
        <details class="filter-group" open>
          <summary>
            <span>Other Variations</span>
            <span class="tooltip ml-2" data-tip="Variation filters are generated from Spree product option values when available.">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-[#CCCCC4] text-[10px] text-[#4A4A42]">?</span>
            </span>
          </summary>

          <div class="mt-3 space-y-5 pb-1">
            <% @variation_groups.each do |group| %>
              <div>
              <p class="mb-2 text-sm font-semibold text-[#0D0D0D]"><%= group[:label] %></p>
              <div class="space-y-2">
                <% group[:values].first(10).each do |entry| %>
                  <label class="flex cursor-pointer items-center gap-2 rounded-xl px-2 py-1.5 hover:bg-black/5">
                    <input
                      type="checkbox"
                      name="variation[<%= group[:key] %>][]"
                      value="<%= entry[:value] %>"
                      class="checkbox checkbox-sm rounded-md"
                      <%= "checked" if Array(@variation_filters[group[:key]]).include?(entry[:value]) %>
                      data-action="change->catalog-filters#submit"
                    >
                    <span class="text-sm text-[#4A4A42]"><%= entry[:value] %> (<%= entry[:count] %>)</span>
                  </label>
                <% end %>
              </div>
              </div>
            <% end %>
          </div>
        </details>
      <% end %>

      <div class="flex flex-wrap gap-2 border-t border-[#E8E8E2] pt-5">
        <button type="submit" class="<%= quick_action_classes(:primary) %>">Apply filters</button>
        <%= link_to "Reset", products_path, class: quick_action_classes(:secondary) %>
      </div>
      <% end %>
    </aside>

    <div>
      <div class="mb-6 flex flex-wrap items-center justify-between gap-2" data-reveal data-reveal-delay="70">
      <p class="text-sm text-[#8A8A80]">Showing <span class="font-semibold text-[#0D0D0D]"><%= @products.count %></span> of <span class="font-semibold text-[#0D0D0D]"><%= @products_total %></span> products</p>
      <div class="flex flex-wrap gap-2">
        <% if @category.present? %>
          <span class="tooltip" data-tip="Category filter active">
            <span class="search-chip"><%= @category %></span>
          </span>
        <% end %>
        <% @variation_filters.each do |key, values| %>
          <% values.each do |value| %>
            <span class="tooltip" data-tip="Variation filter active">
              <span class="search-chip"><%= key.humanize %>: <%= value %></span>
            </span>
          <% end %>
        <% end %>
        <% @size_filters.each do |value| %>
          <span class="tooltip" data-tip="Size filter active">
            <span class="search-chip">Size: <%= value %></span>
          </span>
        <% end %>
        <% @price_groups.each do |group| %>
          <% next unless @price_filters.include?(group[:key]) %>
          <span class="tooltip" data-tip="Price variant active">
            <span class="search-chip">Price: <%= group[:label] %></span>
          </span>
        <% end %>
      </div>
    </div>

      <% if @products.any? %>
        <div class="product-grid">
          <% @products.each_with_index do |product, index| %>
            <div data-reveal data-reveal-delay="<%= [80 + (index * 15), 240].min %>">
              <%= render "shared/product_card", product: product %>
            </div>
          <% end %>
        </div>
      <% else %>
        <%= render "shared/empty_state", title: "No products match your filters", description: "Try broadening category or variation filters.", action: { label: "Clear filters", path: products_path, style: :primary } %>
      <% end %>
    </div>
  </section>
<% end %>
