<%= render "shared/breadcrumbs", items: [
  { label: "Home", path: root_path },
  { label: "Shop", path: products_path },
  { label: "Your Bag" }
] %>

<%= render "shared/page_header",
  eyebrow: "Storefront Cart",
  title: "Your Bag",
  description: "Review items, adjust quantities, and continue to checkout.",
  actions: [{ label: "Continue shopping", path: products_path, style: :secondary }] %>

<section class="mt-4 grid gap-4 xl:grid-cols-[1.2fr_0.8fr]">
  <article class="surface-panel p-5">
    <% if @items.any? %>
      <ul class="space-y-3">
        <% @items.each do |item| %>
          <% product = item.product %>
          <li class="rounded-2xl border border-[#E8E8E2] p-4">
            <div class="flex flex-wrap items-start gap-4">
              <% if product.image_url.present? %>
                <img src="<%= product.image_url %>" alt="<%= product.name %>" class="h-20 w-20 rounded-xl object-cover">
              <% else %>
                <div class="grid h-20 w-20 place-items-center rounded-xl bg-[#F4F4F0] text-xs text-[#8A8A80]">No image</div>
              <% end %>

              <div class="flex-1">
                <p class="text-lg font-semibold text-[#0D0D0D]"><%= product.name %></p>
                <p class="mt-1 text-sm text-[#4A4A42]"><%= product.maker_name %></p>
                <p class="mt-1 text-sm font-semibold text-[#0D0D0D]"><%= number_to_currency(item.unit_price_cents / 100.0) %> each</p>

                <div class="mt-3 flex flex-wrap items-center gap-2">
                  <%= form_with url: storefront_cart_update_item_path(product_id: item.product_slug), method: :patch, class: "flex items-center gap-2" do |f| %>
                    <label class="text-xs font-semibold uppercase tracking-[0.08em] text-[#8A8A80]" for="cart_qty_<%= item.product_slug %>">Qty</label>
                    <%= f.number_field :quantity, value: item.quantity, min: 1, max: 25, id: "cart_qty_#{item.product_slug}", class: "input input-bordered w-20" %>
                    <%= f.submit "Update", class: quick_action_classes(:secondary) %>
                  <% end %>
                  <%= button_to "Remove", storefront_cart_remove_item_path(product_id: item.product_slug), method: :delete, class: quick_action_classes(:secondary) %>
                </div>
              </div>

              <div class="text-right">
                <p class="text-sm text-[#8A8A80]">Line total</p>
                <p class="text-lg font-bold text-[#0D0D0D]"><%= number_to_currency(item.line_total_cents / 100.0) %></p>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <%= render "shared/empty_state",
        title: "Your bag is empty",
        description: "Add handcrafted items from the marketplace to start checkout.",
        action: { label: "Browse products", path: products_path, style: :primary } %>
    <% end %>
  </article>

  <aside class="surface-panel p-5">
    <h2 class="text-xl font-bold text-[#0D0D0D]">Order Summary</h2>
    <dl class="mt-4 space-y-2 text-sm text-[#4A4A42]">
      <div class="flex items-center justify-between">
        <dt>Items</dt>
        <dd><%= @cart.item_count %></dd>
      </div>
      <div class="flex items-center justify-between">
        <dt>Subtotal</dt>
        <dd class="font-semibold text-[#0D0D0D]"><%= number_to_currency(@cart.subtotal_cents / 100.0) %></dd>
      </div>
      <div class="flex items-center justify-between">
        <dt>Shipping</dt>
        <dd>Calculated at checkout</dd>
      </div>
    </dl>

    <div class="mt-5 grid gap-2">
      <%= link_to "Proceed to checkout", checkout_path, class: quick_action_classes(:primary) %>
      <%= button_to "Clear bag", storefront_cart_clear_path, method: :delete, class: quick_action_classes(:secondary), data: { turbo_confirm: "Remove all items from your bag?" } %>
    </div>
  </aside>
</section>
