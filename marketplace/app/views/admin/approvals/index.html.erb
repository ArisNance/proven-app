<%= render "shared/breadcrumbs", items: [
  { label: "Home", path: root_path },
  { label: "Admin approvals" }
] %>

<%= render "shared/page_header",
  eyebrow: "Admin Console",
  title: "Review Queues",
  description: "Approve or reject submissions with clear risk context and queue visibility.",
  actions: [{ label: "Admin home", path: admin_root_path, style: :secondary }] %>

<section class="info-grid">
  <article class="metric-tile">
    <p class="metric-label">Makers pending</p>
    <p class="metric-value"><%= @maker_applications.count %></p>
  </article>
  <article class="metric-tile">
    <p class="metric-label">Shops pending</p>
    <p class="metric-value"><%= @shop_approvals.count %></p>
  </article>
  <article class="metric-tile">
    <p class="metric-label">Products pending</p>
    <p class="metric-value"><%= @product_approvals.count %></p>
  </article>
  <article class="metric-tile">
    <p class="metric-label">Flags open</p>
    <p class="metric-value"><%= @flagged_items.count %></p>
  </article>
  <article class="metric-tile">
    <p class="metric-label">Response goal</p>
    <p class="metric-value">24h</p>
  </article>
</section>

<section class="mt-4 grid gap-4 lg:grid-cols-3">
  <article class="surface-panel p-5 lg:col-span-2">
    <h2 class="text-xl font-bold">Maker Verification Queue</h2>
    <% if @maker_applications.any? %>
      <div class="mt-4 space-y-3">
        <% @maker_applications.first(8).each do |application| %>
          <article class="rounded-2xl border border-slate-200 p-4">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-base font-semibold text-slate-900"><%= [application.first_name, application.last_name].join(" ") %></p>
                <p class="text-sm text-slate-600"><%= application.business_name %></p>
                <p class="mt-1 text-xs text-slate-500">Status: <span class="<%= status_pill_class(application.state) %>"><%= application.state.humanize %></span></p>
              </div>
              <div>
                <%= link_to "Review verification", admin_maker_application_path(application), class: quick_action_classes(:secondary) %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
      <div class="mt-4">
        <%= link_to "Open full maker verification queue", admin_maker_applications_path, class: quick_action_classes(:primary) %>
      </div>
    <% else %>
      <p class="mt-2 text-sm text-slate-600">No maker applications waiting for review.</p>
    <% end %>

    <h2 class="mt-8 text-xl font-bold">Shop Approval Queue</h2>
    <% if @shop_approvals.any? %>
      <div class="mt-4 space-y-3">
        <% @shop_approvals.each do |approval| %>
          <article class="rounded-2xl border border-slate-200 p-4">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <p class="text-base font-semibold text-slate-900"><%= approval.shop.name %></p>
                <p class="text-sm text-slate-600"><%= truncate(approval.shop.description.to_s, length: 160) %></p>
                <p class="mt-1 text-xs text-slate-500">Submitted <%= time_ago_in_words(approval.created_at) %> ago</p>
              </div>
              <div class="flex gap-2">
                <%= button_to "Approve", approve_admin_approval_path(approval), method: :post, class: quick_action_classes(:primary) %>
                <%= button_to "Reject", reject_admin_approval_path(approval), method: :post, class: "inline-flex items-center justify-center rounded-full border border-rose-300 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:bg-rose-50" %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <%= render "shared/empty_state", title: "No shops waiting", description: "All current shop submissions are reviewed." %>
    <% end %>
  </article>

  <aside class="space-y-4">
    <section class="surface-panel p-5">
      <h2 class="text-lg font-bold">Product Queue</h2>
      <% if @product_approvals.any? %>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <% @product_approvals.first(6).each do |approval| %>
            <li class="rounded-xl border border-slate-200 p-3">
              Product #<%= approval.product_id %> - <span class="<%= status_pill_class(approval.state) %>"><%= approval.state %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-2 text-sm text-slate-600">No product approvals pending.</p>
      <% end %>
    </section>

    <section class="surface-panel p-5">
      <h2 class="text-lg font-bold">Flagged Items</h2>
      <% if @flagged_items.any? %>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <% @flagged_items.first(6).each do |flag| %>
            <li class="rounded-xl border border-slate-200 p-3">
              <p class="font-medium text-slate-900">Product #<%= flag.product_id %></p>
              <p class="mt-1"><%= truncate(flag.reason, length: 90) %></p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-2 text-sm text-slate-600">No open flags.</p>
      <% end %>
    </section>
  </aside>
</section>
