            <g class="bob-4 interactive">
              <rect x="574" y="334" width="98" height="76" rx="9" fill="#F7F7F3" stroke="#CCC6BC" stroke-width="3"></rect>
              <rect x="586" y="346" width="74" height="26" fill="#FFF4B7"></rect>
              <path d="M590 370l18-16 14 12 12-10 20 14z" fill="#2A2A2A" opacity="0.7"></path>
              <rect x="586" y="378" width="74" height="22" fill="#ECEBE4"></rect>
              <circle cx="606" cy="389" r="5.5" fill="#D67E4A"></circle>
              <rect x="618" y="384" width="20" height="4" rx="2" fill="#1D1D1D"></rect>
              <rect x="618" y="392" width="25" height="4" rx="2" fill="#69675E"></rect>
              <text x="623" y="434" text-anchor="middle" font-size="14" font-family="system-ui, sans-serif" font-weight="600" fill="#5C5B54">Art</text>
            </g>

            <g class="bob-1">
              <rect x="728" y="288" width="14" height="132" rx="7" fill="#8E857A"></rect>
              <rect x="688" y="300" width="94" height="10" rx="5" fill="#8E857A"></rect>

              <g class="interactive">
                <path d="M698 312h34v60h-34z" fill="#F0EFE8" stroke="#C9C2B7" stroke-width="2"></path>
                <path d="M709 316c0-12 8-18 16-18s16 6 16 18" fill="none" stroke="#8E857A" stroke-width="3"></path>
              </g>
              <g class="interactive">
                <path d="M736 316h34v56h-34z" fill="#F7E3CD" stroke="#C9C2B7" stroke-width="2"></path>
                <path d="M747 320c0-10 7-16 14-16s14 6 14 16" fill="none" stroke="#8E857A" stroke-width="3"></path>
              </g>
              <g class="interactive">
                <ellipse cx="712" cy="440" rx="32" ry="10" fill="#BFB9AF"></ellipse>
                <path d="M680 440h64c-5 18-14 28-32 28s-27-10-32-28z" fill="#F1F0E8"></path>
              </g>
              <g class="interactive">
                <ellipse cx="780" cy="442" rx="34" ry="10" fill="#BFB9AF"></ellipse>
