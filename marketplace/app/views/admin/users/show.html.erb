<%= render "shared/breadcrumbs", items: [
  { label: "Admin", path: admin_root_path },
  { label: "Users", path: admin_users_path },
  { label: "User ##{@user.id}" }
] %>

<%= render "shared/page_header",
  eyebrow: "Admin Users",
  title: @user.email,
  description: "Update role assignment and inspect activity counts.",
  actions: [{ label: "Back to users", path: admin_users_path, style: :secondary }] %>

<section class="grid gap-4 lg:grid-cols-2">
  <article class="surface-panel p-5">
    <h2 class="text-lg font-bold">User Snapshot</h2>
    <ul class="mt-3 space-y-2 text-sm text-slate-700">
      <li>Role: <span class="<%= status_pill_class(@user.role) %>"><%= @user.role %></span></li>
      <li>Conversations: <%= @conversations_count %></li>
      <li>Messages: <%= @messages_count %></li>
      <li>Shops: <%= @shops_count %></li>
    </ul>
  </article>

  <article class="surface-panel p-5">
    <h2 class="text-lg font-bold">Edit Role</h2>
    <%= form_with model: @user, url: admin_user_path(@user), method: :patch, class: "mt-3 grid gap-3" do |f| %>
      <div>
        <label class="field-label" for="user_role">Role</label>
        <%= f.select :role, User.roles.keys.map { |role| [role.titleize, role] }, {}, class: "select select-bordered mt-1 w-full" %>
      </div>
      <div>
        <%= f.submit "Save", class: quick_action_classes(:primary) %>
      </div>
    <% end %>

    <%= button_to "Delete user", admin_user_path(@user), method: :delete, class: "mt-4 inline-flex items-center justify-center rounded-full border border-rose-300 px-4 py-2 text-sm font-semibold text-rose-700 transition hover:bg-rose-50", data: { turbo_confirm: "Delete this user and related records?" } %>
  </article>
</section>
