<!DOCTYPE html>
<html lang="en" data-theme="proven">
  <head>
    <title>Proven Marketplace</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="Proven helps buyers discover verified makers and helps makers launch trusted shops.">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Red+Hat+Display:wght@500;600;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", defer: true %>
  </head>

  <body data-controller="micro-motion">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-white focus:px-3 focus:py-2">Skip to content</a>

    <header class="top-nav">
      <div class="app-shell flex items-center justify-between gap-4 py-4">
        <div class="flex items-center gap-3">
          <%= link_to root_path, class: "brand-mark" do %>
            Proven
          <% end %>
        </div>

        <nav aria-label="Primary">
          <ul class="flex flex-wrap items-center gap-1">
            <% header_navigation_items.each do |item| %>
              <li>
                <%= link_to item[:label], item[:path], class: nav_link_classes(current_page?(item[:path])) %>
              </li>
            <% end %>
          </ul>
        </nav>

        <div class="flex items-center gap-2">
          <details class="dropdown dropdown-end">
            <summary class="inline-flex cursor-pointer list-none items-center gap-2 rounded-full border border-[#CCCCC4] px-3 py-2 text-sm font-medium text-[#4A4A42] hover:border-[#0D0D0D]">
              <span>Menu</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 text-[#6D6D63]" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
              </svg>
            </summary>
            <ul class="menu dropdown-content z-[80] mt-2 w-60 rounded-2xl border border-[#E8E8E2] bg-white p-2 shadow-lg">
              <% if dashboard_mode_switch_enabled? %>
                <li><%= link_to "Buyer dashboard", dashboard_index_path(mode: :buyer), class: "rounded-xl text-sm" %></li>
                <li><%= link_to "Maker dashboard", dashboard_index_path(mode: :maker), class: "rounded-xl text-sm" %></li>
              <% end %>
              <% header_dropdown_items.each do |item| %>
                <li><%= link_to item[:label], item[:path], class: "rounded-xl text-sm" %></li>
              <% end %>
              <% if admin_session_authenticated? %>
                <li><%= link_to "Admin sign out", admin_logout_path, data: { turbo_method: :delete }, class: "rounded-xl text-sm" %></li>
              <% end %>
              <% if user_signed_in? %>
                <li><%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "rounded-xl text-sm" %></li>
              <% end %>
            </ul>
          </details>
        </div>
      </div>
    </header>

    <main id="main-content" class="app-shell page-main">
      <%= render "shared/flash" %>
      <div class="mt-4">
        <%= yield %>
      </div>
    </main>

    <footer class="border-t border-[#E8E8E2] bg-[#FAFAF8] py-6">
      <div class="app-shell flex flex-col gap-2 text-sm text-[#8A8A80] md:flex-row md:items-center md:justify-between">
        <p>Proven Marketplace. Every item. Every maker. Verified.</p>
        <p>Built for trusted maker commerce.</p>
      </div>
    </footer>
  </body>
</html>
