<aside class="surface-panel p-4" aria-label="Role quick actions">
  <h2 class="text-sm font-semibold text-slate-700"><%= title || "Quick Actions" %></h2>
  <div class="mt-3 flex flex-wrap gap-2">
    <% actions.each do |action| %>
      <%= link_to action[:label], action[:path], class: quick_action_classes(action[:style] || :secondary) %>
    <% end %>
  </div>
</aside>
