            </g>

            <g class="float-2">
              <g filter="url(#softShadow)" class="interactive">
                <rect x="492" y="66" width="226" height="82" rx="36" fill="#FFFFFF"></rect>
                <circle cx="532" cy="105" r="18" fill="#D4EA3A"></circle>
                <path d="M524 104l6 7 12-13" fill="none" stroke="#111111" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"></path>
