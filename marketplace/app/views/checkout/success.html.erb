<% if @checkout_order.present? %>
  <%= render "shared/breadcrumbs", items: [
    { label: "Home", path: root_path },
    { label: "Checkout", path: checkout_path },
    { label: "Order confirmed" }
  ] %>

  <section class="surface-panel p-6 md:p-8">
    <p class="eyebrow">Order Received</p>
    <h1 class="page-title mt-2">Your order is confirmed.</h1>
    <p class="page-subtitle mt-3">
      Thanks for shopping on Proven. We captured your shipping details and queued your order for ShipStation sync.
    </p>

    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <div class="rounded-2xl border border-[#E8E8E2] bg-[#FCFCFA] p-4 text-sm text-[#4A4A42]">
        <p><strong class="text-[#0D0D0D]">Order reference:</strong> <%= @checkout_order.reference_code %></p>
        <p class="mt-1"><strong class="text-[#0D0D0D]">Status:</strong> <%= @checkout_order.status.humanize %></p>
        <p class="mt-1"><strong class="text-[#0D0D0D]">Total:</strong> <%= number_to_currency(@checkout_order.total_cents / 100.0) %></p>
      </div>

      <div class="rounded-2xl border border-[#E8E8E2] bg-[#FCFCFA] p-4 text-sm text-[#4A4A42]">
        <p class="font-semibold text-[#0D0D0D]">Shipping to</p>
        <p class="mt-1"><%= [@checkout_order.first_name, @checkout_order.last_name].join(" ").squish %></p>
        <p><%= @checkout_order.address1 %></p>
        <% if @checkout_order.address2.present? %>
          <p><%= @checkout_order.address2 %></p>
        <% end %>
        <p><%= [@checkout_order.city, @checkout_order.state, @checkout_order.postal_code].compact.join(", ") %></p>
        <p><%= @checkout_order.country %></p>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <%= link_to "Continue shopping", products_path, class: quick_action_classes(:primary) %>
      <%= link_to "View bag", storefront_cart_path, class: quick_action_classes(:secondary) %>
    </div>
  </section>
<% else %>
  <%= render "shared/breadcrumbs", items: [
    { label: "Home", path: root_path },
    { label: "Checkout", path: checkout_success_path },
    { label: "Success" }
  ] %>

  <section class="surface-panel p-6 md:p-8">
    <p class="eyebrow">Order Received</p>
    <h1 class="page-title mt-2">Payment completed in Stripe test mode.</h1>
    <p class="page-subtitle mt-3">
      Your checkout request was successfully created and completed. Once Stripe webhooks arrive, fee reconciliation and payout metadata will update in the background.
    </p>

    <div class="mt-6 rounded-2xl border border-[#E8E8E2] bg-[#FCFCFA] p-4 text-sm text-[#4A4A42]">
      <% if @checkout_session.present? %>
        <p><strong class="text-[#0D0D0D]">Session:</strong> <%= @checkout_session.id %></p>
        <p class="mt-1"><strong class="text-[#0D0D0D]">Status:</strong> <%= @checkout_session.payment_status %></p>
        <p class="mt-1"><strong class="text-[#0D0D0D]">Amount total:</strong> <%= number_to_currency(@checkout_session.amount_total.to_i / 100.0) %></p>
      <% elsif @checkout_session_id.present? %>
        <p><strong class="text-[#0D0D0D]">Session:</strong> <%= @checkout_session_id %></p>
        <p class="mt-1">Stripe lookup was not available, but the success redirect completed.</p>
      <% else %>
        <p>No Stripe session id was returned.</p>
      <% end %>
    </div>

    <div class="mt-6 flex flex-wrap gap-3">
      <%= link_to "Continue shopping", products_path, class: quick_action_classes(:primary) %>
      <%= link_to "Open dashboard", dashboard_index_path, class: quick_action_classes(:secondary) %>
    </div>
  </section>
<% end %>
