<%= render "shared/breadcrumbs", items: [
  { label: "Home", path: root_path },
  { label: "Sell on Proven" }
] %>

<%= render "shared/page_header",
  eyebrow: "Maker Application",
  title: "Apply to Sell on Proven",
  description: "Every new seller starts as a buyer, then applies for maker verification before opening a shop.",
  actions: [{ label: "Back to dashboard", path: dashboard_index_path, style: :secondary }] %>

<section class="grid gap-4 xl:grid-cols-[1.15fr_0.85fr]">
  <article class="form-card">
    <%= render "shared/form_error_summary", record: @maker_application %>

    <%= form_with model: @maker_application, url: makers_onboarding_path, class: "grid gap-4 md:grid-cols-2", data: { controller: "form-state" } do |f| %>
      <div>
        <label class="field-label" for="maker_application_first_name">Maker first name <span class="field-meta">Required</span></label>
        <%= f.text_field :first_name, class: "input input-bordered mt-1 w-full", required: true, autocomplete: "given-name" %>
        <%= inline_field_error(@maker_application, :first_name) %>
      </div>

      <div>
        <label class="field-label" for="maker_application_last_name">Maker last name <span class="field-meta">Required</span></label>
        <%= f.text_field :last_name, class: "input input-bordered mt-1 w-full", required: true, autocomplete: "family-name" %>
        <%= inline_field_error(@maker_application, :last_name) %>
      </div>

      <div>
        <label class="field-label" for="maker_application_email">Email address <span class="field-meta">Required</span></label>
        <%= f.email_field :email, class: "input input-bordered mt-1 w-full", required: true, autocomplete: "email" %>
        <%= inline_field_error(@maker_application, :email) %>
      </div>

      <div>
        <label class="field-label" for="maker_application_business_name">Business name <span class="field-meta">Required</span></label>
        <%= f.text_field :business_name, class: "input input-bordered mt-1 w-full", required: true %>
        <%= inline_field_error(@maker_application, :business_name) %>
      </div>

      <div class="md:col-span-2">
        <label class="field-label" for="maker_application_business_url">Business URL <span class="field-meta">Required</span></label>
        <%= f.url_field :business_url, class: "input input-bordered mt-1 w-full", required: true, placeholder: "https://your-site-or-social-link.com" %>
        <p class="field-hint">Use your website or a social profile URL.</p>
        <%= inline_field_error(@maker_application, :business_url) %>
      </div>

      <div class="md:col-span-2">
        <label class="field-label" for="maker_application_what_do_you_make">What do you make? <span class="field-meta">Required</span></label>
        <%= f.text_field :what_do_you_make, class: "input input-bordered mt-1 w-full", required: true, maxlength: 160, placeholder: "Short answer (example: hand-thrown ceramics and mugs)." %>
        <%= inline_field_error(@maker_application, :what_do_you_make) %>
      </div>

      <div class="md:col-span-2">
        <label class="field-label" for="maker_application_how_long_making">How long have you been making this? <span class="field-meta">Optional</span></label>
        <%= f.select :how_long_making,
          options_for_select(MakerApplication::HOW_LONG_OPTIONS, @maker_application.how_long_making),
          { include_blank: "Select one" },
          class: "select select-bordered mt-1 w-full" %>
        <%= inline_field_error(@maker_application, :how_long_making) %>
      </div>

      <div class="md:col-span-2 mt-2 flex flex-wrap gap-2">
        <%= f.submit "Submit maker application", class: quick_action_classes(:primary), data: { form_state_target: "submit" } %>
        <%= link_to "Cancel", dashboard_index_path, class: quick_action_classes(:secondary) %>
      </div>
    <% end %>
  </article>

  <aside class="space-y-4">
    <section class="surface-panel p-5">
      <h2 class="text-lg font-bold">Application Status</h2>
      <% if @maker_application.persisted? %>
        <p class="mt-3 text-sm text-[#4A4A42]">
          Current status:
          <span class="<%= status_pill_class(@maker_application.state) %>"><%= @maker_application.state.humanize %></span>
        </p>
        <% if @maker_application.submitted_at.present? %>
          <p class="mt-2 text-xs text-[#8A8A80]">Submitted <%= time_ago_in_words(@maker_application.submitted_at) %> ago</p>
        <% end %>
        <% if @maker_application.accepted? %>
          <div class="mt-4">
            <%= link_to "Continue to maker onboarding", makers_profile_onboarding_path, class: quick_action_classes(:primary) %>
          </div>
        <% end %>
      <% else %>
        <p class="mt-3 text-sm text-[#4A4A42]">No submission yet. Complete the form to enter admin verification.</p>
      <% end %>
    </section>

    <section class="surface-panel p-5">
      <h2 class="text-lg font-bold">What happens next</h2>
      <ol class="mt-3 space-y-2 text-sm text-[#4A4A42]">
        <li>1. Admin reviews your application and verification evidence.</li>
        <li>2. Accepted makers complete legal/business onboarding and shop policy setup.</li>
        <li>3. Your shop profile goes live with your public maker story.</li>
      </ol>
    </section>
  </aside>
</section>

