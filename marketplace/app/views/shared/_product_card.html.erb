<article class="product-tile group" data-tilt>
  <%= link_to product_path(product.slug), class: "block", data: { turbo_frame: "_top" } do %>
    <div class="product-media">
      <% if product.image_url.present? %>
        <img src="<%= product.image_url %>" alt="<%= product.name %>">
      <% else %>
        <div class="grid h-full place-items-center text-sm text-[#8A8A80]">Image coming soon</div>
      <% end %>

      <span class="product-add" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
      </span>
    </div>

    <div class="px-1">
      <div class="mb-1 flex items-start justify-between gap-3">
        <h3 class="text-lg font-bold leading-tight text-[#0D0D0D] group-hover:text-[#4A4A42]"><%= product.name %></h3>
        <span class="font-header text-lg font-bold text-[#0D0D0D]"><%= number_to_currency(product.price_cents.to_f / 100) %></span>
      </div>
      <p class="text-sm text-[#8A8A80]"><%= product.maker_name %> - <%= product.material %></p>
      <p class="mt-1 inline-flex rounded-full bg-[#F4F4F0] px-2 py-1 text-xs font-semibold text-[#4A4A42]"><%= product.category %></p>
    </div>
  <% end %>
</article>
