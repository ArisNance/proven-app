<%= render "shared/breadcrumbs", items: [
  { label: "Admin", path: admin_root_path },
  { label: "Users" }
] %>

<%= render "shared/page_header",
  eyebrow: "Admin Users",
  title: "Manage Users",
  description: "Review, edit role assignments, and remove users when needed.",
  actions: [{ label: "Admin home", path: admin_root_path, style: :secondary }] %>

<section class="surface-panel p-5">
  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Email</th>
          <th>Role</th>
          <th>Created</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @users.each do |user| %>
          <tr>
            <td><%= user.id %></td>
            <td><%= user.email %></td>
            <td><span class="<%= status_pill_class(user.role) %>"><%= user.role %></span></td>
            <td><%= l(user.created_at, format: :short) %></td>
            <td><%= link_to "Open", admin_user_path(user), class: quick_action_classes(:secondary) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
